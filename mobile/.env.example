# Supabase (Phase 2) — copy to mobile/.env and fill from Supabase Dashboard → Project Settings → API
# Never commit mobile/.env

EXPO_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your_publishable_key_here

# Optional: preview compatibility warning banner UI (restart Expo after change)
# EXPO_PUBLIC_FORCE_COMPATIBILITY_BANNER=true

# Optional: App Store / Play Store / EAS update page for Settings "Get update" button
# Use platform-specific URLs when you have both store listings; or one generic landing page:
# EXPO_PUBLIC_APP_UPDATE_URL=https://boundfortheroad.com/download
# EXPO_PUBLIC_APP_UPDATE_URL_IOS=https://apps.apple.com/app/idXXXXXXXX
# EXPO_PUBLIC_APP_UPDATE_URL_ANDROID=https://play.google.com/store/apps/details?id=com.example.app

# Optional: proximity dev — pretend a linked adult is on the LAN at session submit (see docs/PROXIMITY.md)
# EXPO_PUBLIC_PROXIMITY_MOCK_ADULT_ID=your-adult-user-uuid
